# -----------------------------------------------------------------------------
# TICKETERA SOC - CONFIGURACIÓN DE ENTORNO (EJEMPLO)
# -----------------------------------------------------------------------------

# --- BASE DE DATOS (PostgreSQL) ---
POSTGRES_USER=operador_db
POSTGRES_PASSWORD=ClaveSegura123!
POSTGRES_DB=ticketera_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# URL de conexión (Debe coincidir con las credenciales de arriba)
# Formato: postgresql+asyncpg://<USER>:<PASS>@<HOST>:<PORT>/<DB>
DATABASE_URL=postgresql+asyncpg://operador_db:ClaveSegura123!@db:5432/ticketera_db

# --- SEGURIDAD BACKEND ---
# Generar una clave fuerte de 64 caracteres: openssl rand -hex 32
SECRET_KEY=UnaClaveMuyLargaYAleatoriaDe64CaracteresParaJWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CONFIGURACIÓN DE RED ---
# Reemplazar con la IP o Dominio real del servidor
DOMAIN_NAME=10.1.1.1
DOMAIN_NAME_FRONT=https://10.1.1.1

# --- ADMINISTRADOR INICIAL ---
# Estos datos se usarán para crear el superusuario automáticamente en el primer arranque
FIRST_SUPERUSER=admin@institucion.gob.ar
FIRST_SUPERUSER_PASSWORD=AdminPassword2026!

# --- BÚSQUEDA (Meilisearch) ---
MEILI_MASTER_KEY=masterKeyTicketeraSOC2026

# --- INTEGRACIONES EXTERNAS ---
# VirusTotal API Key para escaneo de adjuntos y URLs
VT_API_KEY=tu_clave_de_virustotal_aqui

# --- INTELIGENCIA ARTIFICIAL (Opcional) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
